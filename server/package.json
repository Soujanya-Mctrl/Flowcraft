    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.8.0",
    "groq-sdk": "^0.33.0",
    "helmet": "^8.1.0",
    "pre-commit": "^1.2.2",
    "rimraf": "^6.0.1"
  },
